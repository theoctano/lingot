{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Lingot",
  "scopeName": "source.lingot",
  "fileTypes": ["ling"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#operator-keywords" },
    { "include": "#constants" },
    { "include": "#types" },
    { "include": "#builtins" },
    { "include": "#function-declaration" },
    { "include": "#function-call" },
    { "include": "#operators" },
    { "include": "#punctuation" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.lingot",
          "match": "//.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.lingot",
          "begin": "\"",
          "end": "\"",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.string.begin.lingot" }
          },
          "endCaptures": {
            "0": { "name": "punctuation.definition.string.end.lingot" }
          },
          "patterns": [
            {
              "name": "constant.character.escape.lingot",
              "match": "\\\\[nrt\\\\\"{}]"
            },
            {
              "name": "meta.interpolation.lingot",
              "begin": "\\{",
              "end": "\\}",
              "beginCaptures": {
                "0": { "name": "punctuation.section.interpolation.begin.lingot" }
              },
              "endCaptures": {
                "0": { "name": "punctuation.section.interpolation.end.lingot" }
              },
              "contentName": "meta.embedded.expression.lingot",
              "patterns": [
                { "include": "source.lingot" }
              ]
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.lingot",
          "match": "\\b[0-9]+\\.[0-9]+\\b"
        },
        {
          "name": "constant.numeric.integer.lingot",
          "match": "\\b[0-9]+\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.lingot",
          "match": "\\b(if|else|while|repeat|for|in|try|catch|return|fail|load|from)\\b"
        },
        {
          "name": "keyword.declaration.lingot",
          "match": "\\b(let|dyn|pub)\\b"
        },
        {
          "name": "keyword.other.object.lingot",
          "match": "\\bObject\\b"
        }
      ]
    },
    "operator-keywords": {
      "patterns": [
        {
          "name": "keyword.operator.logical.lingot",
          "match": "\\b(and|or|not)\\b"
        },
        {
          "name": "keyword.operator.comparison.lingot",
          "match": "\\b(is|greater|lesser|than|equal)\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.lingot",
          "match": "\\b(true|false)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.lingot",
          "match": "\\b(Text|Number|Bool|List|Void)\\b"
        }
      ]
    },
    "builtins": {
      "patterns": [
        {
          "name": "support.function.builtin.lingot",
          "match": "\\b(display|shell|read|write|move|rename|delete|list|prefix|suffix)(?=\\s*\\()"
        }
      ]
    },
    "function-declaration": {
      "patterns": [
        {
          "match": "\\b(let)\\s+(?:(dyn|pub)\\s+)*([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()",
          "captures": {
            "1": { "name": "keyword.declaration.lingot" },
            "2": { "name": "keyword.declaration.lingot" },
            "3": { "name": "entity.name.function.lingot" }
          }
        }
      ]
    },
    "function-call": {
      "patterns": [
        {
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()",
          "captures": {
            "1": { "name": "entity.name.function.call.lingot" }
          }
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.comparison.lingot",
          "match": "==|!=|>=|<=|>|<"
        },
        {
          "name": "keyword.operator.logical.lingot",
          "match": "&&|\\|\\||!"
        },
        {
          "name": "keyword.operator.arithmetic.lingot",
          "match": "[+\\-*/%]"
        },
        {
          "name": "keyword.operator.assignment.lingot",
          "match": "="
        },
        {
          "name": "keyword.operator.range.lingot",
          "match": "\\.\\."
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.separator.comma.lingot",
          "match": ","
        },
        {
          "name": "punctuation.accessor.dot.lingot",
          "match": "\\."
        },
        {
          "name": "punctuation.separator.colon.lingot",
          "match": ":"
        },
        {
          "name": "punctuation.terminator.semicolon.lingot",
          "match": ";"
        }
      ]
    }
  }
}
